{
	"name": "rezept-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"seed": "npx tsx scripts/seed.ts",
		"build:cap": "bash scripts/build-capacitor.sh",
		"build:ios": "bash scripts/build-capacitor.sh && npx cap open ios",
		"build:android": "CAPACITOR=true npm run build && npx cap sync android && npx cap open android"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@types/better-sqlite3": "^7.6.13",
		"better-sqlite3": "^12.6.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@capacitor/android": "^8.2.0",
		"@capacitor/cli": "^8.2.0",
		"@capacitor/core": "^8.2.0",
		"@capacitor/ios": "^8.2.0",
		"@capacitor/preferences": "^8.0.1",
		"sql.js": "^1.14.1"
	}
}
